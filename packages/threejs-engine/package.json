{
  "name": "@base/threejs-engine",
  "version": "0.1.0",
  "description": "Three.js engine module for the @base ecosystem — renderer, RAF loop, ECS entity manager, asset loader",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@base/engine-core": ">=0.1.0",
    "three": ">=0.160.0"
  },
  "dependencies": {
    "@base/engine-core": "workspace:*"
  },
  "devDependencies": {
    "@types/three": "^0.172.0",
    "three": "^0.172.0",
    "typescript": "^5.6.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  }
}
